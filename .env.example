# ─────────────────────────────────────────────────────────────
#  Proyecto Alexandria-Klee — environment variables
# ─────────────────────────────────────────────────────────────
#
# The app runs WITHOUT any configuration: when MONGODB_URI is not
# set it falls back to the bundled seed dataset (src/data/seed.json),
# so `npm run dev` works out of the box.
#
# To use MongoDB Atlas, set the connection string below and run
# `npm run seed:mongo` once to load the seed data into the cluster.

# MongoDB Atlas connection string (optional — falls back to local seed)
MONGODB_URI=

# Database name (defaults to "klee_gestaltungslehre")
MONGODB_DB=klee_gestaltungslehre
