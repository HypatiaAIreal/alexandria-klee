# ─────────────────────────────────────────────────────────────
#  Proyecto Alexandria-Klee — environment variables
# ─────────────────────────────────────────────────────────────
#
# CONTENT runs WITHOUT configuration: when MONGODB_URI is not set the
# app reads the bundled seed dataset (src/data/seed.json).
#
# AUTH always runs. Without MONGODB_URI, users are stored in a local
# JSON file (.data/users.json) for development; in production set
# MONGODB_URI so users live in the `users` collection on Atlas.

# MongoDB Atlas connection string (optional for content, recommended for auth)
MONGODB_URI=

# Database name (defaults to "klee_gestaltungslehre")
MONGODB_DB=klee_gestaltungslehre

# ── Authentication ──────────────────────────────────────────
# Secret used to sign JWTs. MUST be set to a long random string in
# production (e.g. `openssl rand -base64 48`). A dev fallback is used
# if unset, which is insecure.
AUTH_SECRET=

# Invite code required to register a new account.
ACCESS_CODE=alexandriaklee2026

# ── Manuscript images (Cloudflare R2) ───────────────────────
# The /manuscripts facsimiles & drawings are NOT in the repo. Locally
# they are served from /public/manuscripts (leave this blank). In
# production, host them on Cloudflare R2 and set the public bucket URL
# here — every "/manuscripts/BG/I/02/001/page.jpg" is then served from
# "${R2_PUBLIC_URL}/BG/I/02/001/page.jpg". No trailing slash.
#   e.g. R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL=
